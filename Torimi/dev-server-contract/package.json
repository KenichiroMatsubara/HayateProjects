{
  "name": "@torimi/dev-server-contract",
  "version": "0.1.0",
  "description": "Torimi Dev Server の wire 契約（App Bundle route・reload route・reload message）。dev-server と host-web の双方が対等に参照する唯一の入口（ADR-0001）。",
  "license": "Apache-2.0",
  "repository": { "type": "git", "url": "https://github.com/KenichiroMatsubara/HayateProjects" },
  "publishConfig": { "access": "public" },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rimraf dist"
  },
  "devDependencies": {
    "rimraf": "^6.1.3",
    "tsup": "^8.5.1",
    "vitest": "^3.2.0"
  }
}
