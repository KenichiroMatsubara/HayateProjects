{
  "name": "@torimi/cli",
  "version": "0.1.0",
  "description": "Torimi orchestrator CLI（Expo の `expo` 相当）— アプリが宣言したビルドを回し、ターゲット固有の Hermes 降格を施し、@torimi/dev-server で配信・reload・QR まで面倒を見る。バンドラも FW も解さない（ADR-0008）。",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/KenichiroMatsubara/HayateProjects"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "bin": {
    "torimi": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prepublishOnly": "node -e \"process.env.GITHUB_ACTIONS||(console.error('publish only via the release workflow (ADR-0007 §4)'),process.exit(1))\"",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@babel/core": "^8.0.1",
    "@babel/preset-env": "^8.0.2",
    "@torimi/dev-server": "workspace:*"
  },
  "devDependencies": {
    "@types/babel__core": "^7.20.5",
    "@types/node": "^26.1.1",
    "rimraf": "^6.1.3",
    "tsup": "^8.5.1",
    "vitest": "^4.1.10"
  }
}
