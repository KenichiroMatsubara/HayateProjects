{
  "name": "@torimi/bundle",
  "version": "0.1.0",
  "description": "Bundle Registration — App Bundle 側の合成ルート。アプリは registerTorimiApp(mount) を呼ぶ全ターゲット共通の 1 エントリだけを書き、protocol version 焼き込み・mount seam（__torimiMount / __tsubame）・native prelude といった wire 契約の配線はこのパッケージが隠す。ターゲット差は __hayateHost の有無でランタイム内部分岐する（ADR-0008 §4 / CONTEXT.md「Bundle Registration」）。",
  "license": "Apache-2.0",
  "repository": { "type": "git", "url": "https://github.com/KenichiroMatsubara/HayateProjects" },
  "publishConfig": { "access": "public" },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./vite": {
      "types": "./dist/vite.d.ts",
      "import": "./dist/vite.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prepublishOnly": "node -e \"process.env.GITHUB_ACTIONS||(console.error('publish only via the release workflow (ADR-0007 §4)'),process.exit(1))\"",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@hayate/host": "workspace:*",
    "@torimi/protocol-handshake": "workspace:*",
    "@tsubame/app": "workspace:*",
    "@tsubame/renderer-hayate": "workspace:*"
  },
  "peerDependencies": {
    "vite": "^8.0.0"
  },
  "peerDependenciesMeta": {
    "vite": { "optional": true }
  },
  "devDependencies": {
    "@torimi/host-web": "workspace:*",
    "rimraf": "^6.1.3",
    "tsup": "^8.5.1",
    "vite": "^8.0.14",
    "vitest": "^3.2.0"
  }
}
