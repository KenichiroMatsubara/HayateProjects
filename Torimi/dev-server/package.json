{
  "name": "@torimi/dev-server",
  "version": "0.1.0",
  "description": "Torimi 最小 dev server — Tsubame App Bundle（単一 JS）を HTTP で配信するだけのツール。watch / WS / protocol version は後続スライス（CONTEXT.md / ADR-0001）。",
  "license": "Apache-2.0",
  "repository": { "type": "git", "url": "https://github.com/KenichiroMatsubara/HayateProjects" },
  "publishConfig": { "access": "public" },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prepublishOnly": "node -e \"process.env.GITHUB_ACTIONS||(console.error('publish only via the release workflow (ADR-0007 §4)'),process.exit(1))\"",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@torimi/dev-server-contract": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "jsqr": "^1.4.0",
    "rimraf": "^6.1.3",
    "tsup": "^8.5.1",
    "vitest": "^4.1.10"
  }
}
