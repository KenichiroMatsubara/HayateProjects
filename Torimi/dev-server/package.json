{
  "name": "@torimi/dev-server",
  "version": "0.0.0",
  "private": true,
  "description": "Torimi 最小 dev server — Tsubame App Bundle（単一 JS）を HTTP で配信するだけのツール。watch / WS / protocol version は後続スライス（CONTEXT.md / ADR-0001）。",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@torimi/dev-server-contract": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.19.0",
    "jsqr": "^1.4.0",
    "rimraf": "^6.1.3",
    "tsup": "^8.5.1",
    "vitest": "^3.2.0"
  }
}
