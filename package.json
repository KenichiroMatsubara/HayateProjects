{
  "name": "hayate-projects",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "preinstall": "node scripts/bootstrap-wasm-pkgs.mjs",

    "build":      "pnpm -r --filter \"!tsubame-monorepo\" run build",
    "typecheck":  "pnpm -r --filter \"!tsubame-monorepo\" run typecheck",
    "test":       "pnpm -r --filter \"!tsubame-monorepo\" run test",
    "clean":      "pnpm -r --filter \"!tsubame-monorepo\" run clean",

    "dev":        "pnpm --filter @tsubame/example-solid-demo dev",

    "check:proto":    "pnpm --filter hayate run check:proto && pnpm --filter tsubame-monorepo run check:proto",

    "hayate:desktop:run":     "pnpm --filter hayate run hayate:desktop:run",
    "hayate:desktop:build":   "pnpm --filter hayate run hayate:desktop:build",

    "torimi:native:dev":      "pnpm --filter @tsubame/example-solid-demo run torimi:native:dev",
    "torimi:web:dev":         "pnpm --filter @tsubame/example-solid-demo run torimi:web:dev",
    "torimi:android:install": "pnpm --filter hayate run torimi:android:install",

    "changeset":              "changeset",
    "version:packages":       "changeset version",
    "check:wasm-not-stub":    "node scripts/check-wasm-not-stub.mjs",
    "release":                "node scripts/check-wasm-not-stub.mjs && changeset publish",
    "release:dry-run":        "node scripts/check-wasm-not-stub.mjs && pnpm -r publish --dry-run --no-git-checks"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.7",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  },
  "packageManager": "pnpm@11.8.0"
}
