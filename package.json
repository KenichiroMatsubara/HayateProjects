{
  "name": "hayate-projects",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "gen":            "node Hayate/scripts/gen-from-wit.mjs",
    "gen:check":      "node Hayate/scripts/gen-from-wit.mjs && git diff --exit-code -- Hayate/crates/adapters/web/src/wit_generated.rs Tsubame/packages/renderer-canvas/src/opcodes.ts",
    "build:wasm":     "pnpm --filter hayate build",
    "build:tsubame":  "pnpm --filter ./Tsubame/packages/** build",
    "build":          "pnpm run build:wasm && pnpm run build:tsubame",
    "dev":            "pnpm --filter hayate dev",
    "dev:hello":      "pnpm --filter @tsubame/example-hello-world dev",
    "typecheck":      "pnpm --filter ./Tsubame/packages/** typecheck",
    "test":           "pnpm -r run test",
    "clean":          "pnpm -r run clean"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  },
  "packageManager": "pnpm@11.5.0"
}
