{
  "name": "@tsubame/renderer-dom",
  "version": "0.1.0",
  "description": "Tsubame DOM Renderer — Hayate 不使用・純 JS の IRenderer 実装（CSR）",
  "license": "Apache-2.0",
  "repository": { "type": "git", "url": "https://github.com/KenichiroMatsubara/HayateProjects" },
  "publishConfig": { "access": "public" },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "prebuild": "pnpm --filter @tsubame/protocol-generated run generate",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@tsubame/hayate-css-catalog": "workspace:*",
    "@tsubame/protocol-generated": "workspace:*",
    "@tsubame/renderer-protocol": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "happy-dom": "^17.4.4",
    "rimraf": "^6.1.3",
    "vitest": "^3.2.0"
  }
}
