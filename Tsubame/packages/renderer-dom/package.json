{
  "name": "@tsubame/renderer-dom",
  "version": "0.0.0",
  "description": "Tsubame DOM Renderer — Hayate 不使用・純 JS の IRenderer 実装（CSR）",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
