    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@tsubame/renderer-protocol": "workspace:*"
  },
  "devDependencies": {
    "rimraf": "^6.0.1"
  }
}
