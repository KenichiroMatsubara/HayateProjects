{
  "name": "@tsubame/hayate-css-catalog",
  "version": "0.0.0",
  "description": "Hayate CSS Catalog — protocol.yaml 駆動の style prop 正本（Canvas encode / DOM CSS / Rust mapper 共通）",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./catalog.json": "./src/catalog.json"
  },
  "files": ["dist", "src/catalog.json"],
  "scripts": {
    "generate": "node scripts/gen-catalog.mjs",
    "prebuild": "npm run generate",
    "pretypecheck": "npm run generate",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@tsubame/renderer-protocol": "workspace:*"
  },
  "devDependencies": {
    "rimraf": "^6.1.3"
  }
}
