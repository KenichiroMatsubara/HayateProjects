{
  "name": "@tsubame/hayate-css-catalog",
  "version": "0.1.0",
  "description": "Hayate CSS Catalog — protocol spec 駆動の style prop 正本（Canvas encode / DOM CSS / Rust mapper 共通）",
  "license": "Apache-2.0",
  "repository": { "type": "git", "url": "https://github.com/KenichiroMatsubara/HayateProjects" },
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "files": ["dist"],
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  },
  "scripts": {
    "prebuild": "pnpm --filter @tsubame/protocol-generated run generate",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@tsubame/protocol-generated": "workspace:*",
    "@tsubame/renderer-protocol": "workspace:*"
  },
  "devDependencies": {
    "rimraf": "^6.1.3"
  }
}
