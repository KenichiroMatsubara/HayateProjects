{
  "name": "@torimi/tsubame-renderer-hayate",
  "version": "0.1.0",
  "description": "Tsubame Canvas Renderer — フレーム単位で mutation をバッチ化し Hayate WASM の apply_mutations へ渡す IRenderer 実装",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/KenichiroMatsubara/HayateProjects"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./test-helpers": {
      "types": "./dist/test-helpers/index.d.ts",
      "import": "./dist/test-helpers/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prepublishOnly": "node -e \"process.env.GITHUB_ACTIONS||(console.error('publish only via the release workflow (ADR-0007 §4)'),process.exit(1))\"",
    "prebuild": "pnpm --filter @torimi/tsubame-protocol-generated run generate",
    "pretypecheck": "pnpm --filter @torimi/tsubame-protocol-generated run generate",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run --project unit",
    "test:wasm": "vitest run --project wasm",
    "test:watch": "vitest",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@torimi/tsubame-hayate-css-catalog": "workspace:*",
    "@torimi/tsubame-protocol-generated": "workspace:*",
    "@torimi/tsubame-renderer-protocol": "workspace:*"
  },
  "devDependencies": {
    "@torimi/tsubame-renderer-dom": "workspace:*",
    "@torimi/tsubame-solid": "workspace:*",
    "@types/node": "^26.1.1",
    "happy-dom": "^20.11.0",
    "hayate-adapter-web-null": "workspace:*",
    "rimraf": "^6.1.3",
    "solid-js": "^1.9.14",
    "vitest": "^4.1.10"
  }
}
