{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "jsx": "react-jsx",
    "jsxImportSource": "@torimi/tsubame-react",
    "paths": {
      "@torimi/tsubame-react/jsx-runtime": ["./src/jsx-runtime.ts"],
      "@torimi/tsubame-react/jsx-dev-runtime": ["./src/jsx-dev-runtime.ts"]
    }
  },
  "include": ["src"]
}
