{
  "name": "@torimi/tsubame-react",
  "version": "0.1.0",
  "description": "tsubame-react — react-reconciler を Tsubame Renderer Protocol に向け替える Adapter",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/KenichiroMatsubara/HayateProjects"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./jsx-runtime": {
      "types": "./dist/jsx-runtime.d.ts",
      "import": "./dist/jsx-runtime.js"
    },
    "./jsx-dev-runtime": {
      "types": "./dist/jsx-dev-runtime.d.ts",
      "import": "./dist/jsx-dev-runtime.js"
    },
    "./vite": {
      "types": "./dist/vite.d.ts",
      "import": "./dist/vite.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prepublishOnly": "node -e \"process.env.GITHUB_ACTIONS||(console.error('publish only via the release workflow (ADR-0007 §4)'),process.exit(1))\"",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@torimi/tsubame-renderer-protocol": "workspace:*"
  },
  "peerDependencies": {
    "react": "^19.2.8",
    "react-reconciler": "^0.33.0",
    "vite": "^8.1.5"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    }
  },
  "devDependencies": {
    "@torimi/tsubame-protocol-generated": "workspace:*",
    "@torimi/tsubame-renderer-hayate": "workspace:*",
    "@types/react": "^19.2.17",
    "@types/react-reconciler": "^0.33.0",
    "react": "^19.2.8",
    "react-reconciler": "^0.33.0",
    "rimraf": "^6.1.3",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  }
}
