{
  "name": "@tsubame/react",
  "version": "0.0.0",
  "description": "tsubame-react — react-reconciler を Tsubame Renderer Protocol に向け替える Adapter",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./jsx-runtime": {
      "types": "./dist/jsx-runtime.d.ts",
      "import": "./dist/jsx-runtime.js"
    },
    "./jsx-dev-runtime": {
      "types": "./dist/jsx-dev-runtime.d.ts",
      "import": "./dist/jsx-dev-runtime.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@tsubame/renderer-protocol": "workspace:*"
  },
  "peerDependencies": {
    "react": "^19.1.0",
    "react-reconciler": "^0.32.0"
  },
  "devDependencies": {
    "@tsubame/protocol-generated": "workspace:*",
    "@tsubame/renderer-hayate": "workspace:*",
    "@types/react": "^19.1.0",
    "@types/react-reconciler": "^0.32.0",
    "react": "^19.1.0",
    "react-reconciler": "^0.32.0",
    "rimraf": "^6.1.3",
    "vitest": "^3.2.6"
  }
}
