{
  "name": "@torimi/tsubame-solid",
  "version": "0.1.0",
  "description": "tsubame-solid — solid-js/universal を Tsubame Renderer Protocol に向け替える Adapter",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/KenichiroMatsubara/HayateProjects"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./vite": {
      "types": "./dist/vite.d.ts",
      "import": "./dist/vite.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prepublishOnly": "node -e \"process.env.GITHUB_ACTIONS||(console.error('publish only via the release workflow (ADR-0007 §4)'),process.exit(1))\"",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@torimi/tsubame-renderer-protocol": "workspace:*"
  },
  "peerDependencies": {
    "solid-js": "^1.9.14",
    "vite": "^8.1.5",
    "vite-plugin-solid": "^2.11.13"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    },
    "vite-plugin-solid": {
      "optional": true
    }
  },
  "devDependencies": {
    "@torimi/tsubame-protocol-generated": "workspace:*",
    "@torimi/tsubame-renderer-hayate": "workspace:*",
    "rimraf": "^6.1.3",
    "solid-js": "^1.9.14",
    "vite": "^8.1.5",
    "vite-plugin-solid": "^2.11.13",
    "vitest": "^4.1.10"
  }
}
