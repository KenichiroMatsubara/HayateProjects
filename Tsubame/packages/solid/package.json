{
  "name": "@tsubame/solid",
  "version": "0.0.0",
  "description": "tsubame-solid — solid-js/universal を Tsubame Renderer Protocol に向け替える Adapter",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@tsubame/renderer-protocol": "workspace:*"
  },
  "peerDependencies": {
    "solid-js": "^1.9.0"
  },
  "devDependencies": {
    "@tsubame/protocol-generated": "workspace:*",
    "@tsubame/renderer-hayate": "workspace:*",
    "rimraf": "^6.1.3",
    "solid-js": "^1.9.13",
    "vitest": "^3.2.6"
  }
}
