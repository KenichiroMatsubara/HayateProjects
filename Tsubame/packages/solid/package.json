{
  "name": "@tsubame/solid",
  "version": "0.1.0",
  "description": "tsubame-solid — solid-js/universal を Tsubame Renderer Protocol に向け替える Adapter",
  "license": "Apache-2.0",
  "repository": { "type": "git", "url": "https://github.com/KenichiroMatsubara/HayateProjects" },
  "publishConfig": { "access": "public" },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./vite": {
      "types": "./dist/vite.d.ts",
      "import": "./dist/vite.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@tsubame/renderer-protocol": "workspace:*"
  },
  "peerDependencies": {
    "solid-js": "^1.9.0",
    "vite": "^8.0.0",
    "vite-plugin-solid": "^2.11.0"
  },
  "peerDependenciesMeta": {
    "vite": { "optional": true },
    "vite-plugin-solid": { "optional": true }
  },
  "devDependencies": {
    "@tsubame/protocol-generated": "workspace:*",
    "@tsubame/renderer-hayate": "workspace:*",
    "rimraf": "^6.1.3",
    "solid-js": "^1.9.13",
    "vite": "^8.0.14",
    "vite-plugin-solid": "^2.11.12",
    "vitest": "^3.2.6"
  }
}
