{
  "name": "@tsubame/renderer-protocol",
  "version": "0.1.0",
  "description": "Tsubame Renderer Protocol — IRenderer インターフェースと型定義（DOM / Canvas Renderer 共通の境界）",
  "license": "Apache-2.0",
  "repository": { "type": "git", "url": "https://github.com/KenichiroMatsubara/HayateProjects" },
  "publishConfig": { "access": "public" },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rimraf dist"
  },
  "devDependencies": {
    "rimraf": "^6.1.3",
    "vitest": "^3.2.0"
  }
}
