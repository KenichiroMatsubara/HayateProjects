{
  "name": "@tsubame/renderer-canvas",
  "version": "0.0.0",
  "description": "Tsubame Canvas Renderer — フレーム単位で mutation をバッチ化し Hayate WASM の apply_mutations へ渡す IRenderer 実装",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./android": {
      "types": "./dist/android.d.ts",
      "import": "./dist/android.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prebuild": "pnpm --filter @tsubame/protocol-generated run generate",
    "pretypecheck": "pnpm --filter @tsubame/protocol-generated run generate",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run --project unit",
    "test:wasm": "vitest run --project wasm",
    "test:watch": "vitest",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@tsubame/hayate-css-catalog": "workspace:*",
    "@tsubame/protocol-generated": "workspace:*",
    "@tsubame/renderer-protocol": "workspace:*",
    "hayate-adapter-web": "file:../../../Hayate/wasm-pkgs/pkg",
    "hayate-adapter-web-cpu": "file:../../../Hayate/wasm-pkgs/pkg-tiny-skia",
    "hayate-adapter-web-null": "file:../../../Hayate/wasm-pkgs/pkg-null"
  },
  "devDependencies": {
    "@tsubame/solid": "workspace:*",
    "happy-dom": "^17.6.3",
    "rimraf": "^6.1.3",
    "solid-js": "^1.9.13",
    "vitest": "^3.2.0"
  }
}
