{
  "name": "@tsubame/app",
  "version": "0.0.0",
  "description": "Tsubame 合成ルート — runTsubameApp（Host が renderer を産み、唯一の FW 固有 mount seam に畳む）と web 専用の detectMode。@tsubame/renderer-protocol だけに依存し、具体 renderer も Hayate ランタイムも知らない（ADR-0012）。",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@tsubame/renderer-protocol": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "rimraf": "^6.1.3",
    "vitest": "^3.2.0"
  }
}
