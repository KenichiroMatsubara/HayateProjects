{
  "name": "@tsubame/protocol-generated",
  "version": "0.1.0",
  "description": "Tsubame protocol codegen — wire constants and adapter vocabulary from @hayate/protocol-spec",
  "license": "Apache-2.0",
  "repository": { "type": "git", "url": "https://github.com/KenichiroMatsubara/HayateProjects" },
  "type": "module",
  "exports": {
    ".": "./generated/index.ts",
    "./protocol": "./generated/protocol.ts",
    "./codec": "./generated/codec.ts",
    "./catalog": "./generated/catalog.ts",
    "./catalog.json": "./generated/catalog.json",
    "./delivery": "./generated/delivery.ts",
    "./recorder": "./generated/recorder.ts"
  },
  "files": ["dist"],
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js" },
      "./protocol": { "types": "./dist/protocol.d.ts", "import": "./dist/protocol.js" },
      "./codec": { "types": "./dist/codec.d.ts", "import": "./dist/codec.js" },
      "./catalog": { "types": "./dist/catalog.d.ts", "import": "./dist/catalog.js" },
      "./catalog.json": "./dist/catalog.json",
      "./delivery": { "types": "./dist/delivery.d.ts", "import": "./dist/delivery.js" },
      "./recorder": { "types": "./dist/recorder.d.ts", "import": "./dist/recorder.js" }
    }
  },
  "scripts": {
    "generate": "node generator/generate.mjs",
    "prebuild": "pnpm run generate",
    "build": "tsup",
    "test": "vitest run",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@hayate/protocol-spec": "workspace:*",
    "@tsubame/renderer-protocol": "workspace:*"
  },
  "devDependencies": {
    "rimraf": "^6.1.3",
    "tsup": "^8.5.1",
    "vitest": "^3.2.0"
  }
}
