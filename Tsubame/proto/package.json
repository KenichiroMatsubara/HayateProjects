{
  "name": "@torimi/tsubame-protocol-generated",
  "version": "0.1.0",
  "description": "Tsubame protocol codegen — wire constants and adapter vocabulary from @torimi/hayate-protocol-spec",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/KenichiroMatsubara/HayateProjects"
  },
  "type": "module",
  "exports": {
    ".": "./generated/index.ts",
    "./protocol": "./generated/protocol.ts",
    "./codec": "./generated/codec.ts",
    "./catalog": "./generated/catalog.ts",
    "./catalog.json": "./generated/catalog.json",
    "./delivery": "./generated/delivery.ts",
    "./edit-intent": "./generated/edit-intent.ts",
    "./recorder": "./generated/recorder.ts"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "./protocol": {
        "types": "./dist/protocol.d.ts",
        "import": "./dist/protocol.js"
      },
      "./codec": {
        "types": "./dist/codec.d.ts",
        "import": "./dist/codec.js"
      },
      "./catalog": {
        "types": "./dist/catalog.d.ts",
        "import": "./dist/catalog.js"
      },
      "./catalog.json": "./dist/catalog.json",
      "./delivery": {
        "types": "./dist/delivery.d.ts",
        "import": "./dist/delivery.js"
      },
      "./edit-intent": {
        "types": "./dist/edit-intent.d.ts",
        "import": "./dist/edit-intent.js"
      },
      "./recorder": {
        "types": "./dist/recorder.d.ts",
        "import": "./dist/recorder.js"
      }
    }
  },
  "scripts": {
    "prepublishOnly": "node -e \"process.env.GITHUB_ACTIONS||(console.error('publish only via the release workflow (ADR-0007 §4)'),process.exit(1))\"",
    "generate": "node generator/generate.mjs",
    "prebuild": "pnpm run generate",
    "build": "tsup",
    "test": "vitest run",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@torimi/hayate-protocol-spec": "workspace:*",
    "@torimi/tsubame-renderer-protocol": "workspace:*"
  },
  "devDependencies": {
    "rimraf": "^6.1.3",
    "tsup": "^8.5.1",
    "vitest": "^4.1.10"
  }
}
