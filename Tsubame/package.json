{
  "name": "tsubame-monorepo",
  "private": true,
  "version": "0.0.0",
  "description": "Tsubame（燕） — JS/TS 向けレンダラーターゲット基盤",
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "build": "pnpm -r run build",
    "typecheck": "pnpm -r run typecheck",
    "test": "pnpm -r run test",
    "generate": "pnpm --filter @torimi/tsubame-protocol-generated run generate",
    "check:proto": "pnpm run generate && git diff --exit-code proto/generated packages/renderer-protocol/src/generated",
    "clean": "pnpm -r run clean",
    "dev": "pnpm --filter @tsubame/example-todo dev"
  },
  "devDependencies": {
    "@babel/core": "^8.0.1",
    "@babel/preset-env": "^8.0.2"
  },
  "packageManager": "pnpm@11.8.0"
}
