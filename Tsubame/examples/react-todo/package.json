{
  "name": "@tsubame/example-react-todo",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "torimi:native:build": "vite build --config vite.config.android.ts && node ../../scripts/lower-for-hermes.mjs dist-android/tsubame.js",
