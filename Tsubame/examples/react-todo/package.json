    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@hayate/host": "workspace:*",
    "@torimi/host-web": "workspace:*",
    "@tsubame/app": "workspace:*",
    "@tsubame/react": "workspace:*",
    "@tsubame/renderer-hayate": "workspace:*",
    "@tsubame/renderer-dom": "workspace:*",
    "@tsubame/renderer-protocol": "workspace:*",
    "react": "^19.1.0",
    "react-reconciler": "^0.32.0"
  },
  "devDependencies": {
    "@torimi/dev-server": "workspace:*",
    "@playwright/test": "^1.61.0",
    "@types/react": "^19.1.0",
    "@types/react-reconciler": "^0.32.0",
    "vite": "^8.0.14",
    "vitest": "^3.2.0"
  }
}
