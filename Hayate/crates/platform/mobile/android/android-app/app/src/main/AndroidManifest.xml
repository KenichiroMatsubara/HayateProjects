<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- wgpu renders via Vulkan on Android (ADR-0002 / ADR-0094). -->
    <uses-feature
        android:name="android.hardware.vulkan.level"
        android:version="1"
        android:required="true" />

    <!-- Torimi のバンドル fetch / reload 購読（OS スタック委譲・Torimi ADR-0002）。 -->
    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:label="Hayate Stage B"
        android:theme="@style/Theme.AppCompat.NoActionBar"
        android:hasCode="true"
        android:networkSecurityConfig="@xml/network_security_config">

        <!-- Google Play services の barcode scanner モジュールを（必要なら）事前に取得させる。
             これで DevServerSetupActivity の「QR スキャン」が初回でも待ち時間少なく開く。
             カメラは Play services のスキャナ UI が扱うので CAMERA permission 宣言は不要。 -->
        <meta-data
            android:name="com.google.mlkit.vision.DEPENDENCIES"
            android:value="barcode_ui" />

        <!-- Torimi の最小 dev-server URL 入力画面（#534）。端末で接続先 URL を入力し、
             internal files dir に書いてからネイティブの GameActivity を明示 Intent で起動する。
             ネイティブはそのファイルを読み戻して fetch / reload の両方を駆動する。 -->
        <activity
            android:name=".DevServerSetupActivity"
            android:exported="true"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- GameActivity host; loads the Rust cdylib that android-activity's
             game-activity backend drives via `android_main`. The native library
             name is declared with `android.app.lib_name` (no `lib` prefix, no
             `.so` suffix). `adjustResize` lets the soft keyboard reflow layout
             for the stage C IME bridge. Launched explicitly from the URL-entry
             screen, so it is no longer the LAUNCHER itself. -->
        <activity
            android:name=".MainActivity"
            android:exported="false"
            android:configChanges="orientation|keyboardHidden|screenSize|screenLayout|density"
            android:windowSoftInputMode="adjustResize">
            <meta-data
                android:name="android.app.lib_name"
                android:value="hayate_adapter_android" />
        </activity>
    </application>
</manifest>
