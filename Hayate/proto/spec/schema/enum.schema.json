{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hayate.dev/proto/spec/schema/enum.schema.json",
  "title": "Protocol enum",
  "type": "object",
  "required": ["name", "values"],
  "properties": {
    "name": { "type": "string", "minLength": 1 },
    "string_values": { "type": "boolean" },
    "values": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "value"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "value": {
            "oneOf": [
              { "type": "integer" },
              { "type": "string", "minLength": 1 }
            ]
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
