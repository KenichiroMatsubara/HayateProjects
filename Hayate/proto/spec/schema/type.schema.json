{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hayate.dev/proto/spec/schema/type.schema.json",
  "title": "Protocol compound type",
  "type": "object",
  "required": ["name", "raw_slots", "fields"],
  "properties": {
    "name": { "type": "string", "minLength": 1 },
    "raw_slots": { "type": "integer", "minimum": 1 },
    "fields": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/param" }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "param": {
      "type": "object",
      "required": ["name", "type"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "type": { "type": "string", "minLength": 1 },
        "count": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": false
    }
  }
}
