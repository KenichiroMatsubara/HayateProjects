{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hayate.dev/proto/spec/schema/simple_entry.schema.json",
  "title": "Protocol simple entry",
  "type": "object",
  "required": ["name", "value"],
  "properties": {
    "name": { "type": "string", "minLength": 1 },
    "value": { "type": "integer", "minimum": 0 },
    "carriesTextLocal": {
      "description": "Text-Local Carrier: element-kind carries channel-1 (text-local) styles as CSS (ADR-0002).",
      "type": "boolean"
    }
  },
  "additionalProperties": false
}
