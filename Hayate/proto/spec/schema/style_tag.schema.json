{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hayate.dev/proto/spec/schema/style_tag.schema.json",
  "title": "Style tag entry with encodeFrom",
  "type": "object",
  "required": ["name", "value", "inherit", "encodeFrom", "domCss"],
  "properties": {
    "name": { "type": "string", "minLength": 1 },
    "value": { "type": "integer", "minimum": 0 },
    "inherit": {
      "description": "Style Channel: which inheritance channel this property belongs to (CONTEXT.md / ADR-0065).",
      "type": "string",
      "enum": ["text-local", "ambient", "none"]
    },
    "variable_length": { "type": "boolean" },
    "encodeFrom": {
      "type": "string",
      "enum": [
        "css-color",
        "dimension",
        "f32",
        "u32",
        "enum:display",
        "enum:flex_direction",
        "enum:flex_wrap",
        "enum:align_items",
        "enum:align_self",
        "enum:align_content",
        "enum:justify_content",
        "enum:font_style",
        "enum:text_decoration",
        "enum:border_style",
        "enum:cursor",
        "enum:overflow",
        "enum:position",
        "enum:text_overflow",
        "enum:transition_timing",
        "enum:box_sizing",
        "enum:grid_auto_flow",
        "enum:justify_items",
        "enum:justify_self",
        "font-family",
        "dimension-list",
        "shadow-list",
        "z-index"
      ]
    },
    "params": {
      "type": "array",
      "items": { "$ref": "entry.schema.json#/$defs/param" }
    },
    "domCss": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/domCss" }
      ]
    }
  },
  "additionalProperties": false,
  "$defs": {
    "domCss": {
      "type": "object",
      "required": ["property", "format"],
      "properties": {
        "property": { "type": "string", "minLength": 1 },
        "format": {
          "type": "string",
          "enum": [
            "color",
            "dimension",
            "px",
            "ms",
            "number",
            "integer",
            "string",
            "grid-span",
            "enum:display",
            "enum:flex_direction",
            "enum:flex_wrap",
            "enum:align_items",
            "enum:align_self",
            "enum:align_content",
            "enum:justify_content",
            "enum:font_style",
            "enum:text_decoration",
            "enum:border_style",
            "enum:cursor",
            "enum:overflow",
            "enum:position",
            "enum:text_overflow",
            "enum:transition_timing",
            "enum:box_sizing",
            "enum:grid_auto_flow",
            "enum:justify_items",
            "enum:justify_self",
            "dimension-list",
            "shadow-list"
          ]
        },
        "extras": {
          "type": "array",
          "items": { "$ref": "#/$defs/domExtra" }
        }
      },
      "additionalProperties": false
    },
    "domExtra": {
      "type": "object",
      "required": ["property", "whenPositive", "whenZero"],
      "properties": {
        "property": { "type": "string", "minLength": 1 },
        "whenPositive": { "type": "string" },
        "whenZero": { "type": "string" }
      },
      "additionalProperties": false
    }
  }
}
