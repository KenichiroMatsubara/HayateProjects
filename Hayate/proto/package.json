{
  "name": "@torimi/hayate-protocol-spec",
  "version": "0.1.0",
  "description": "Hayate-Tsubame Protocol Contract — JSON spec (ADR-0053)",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/KenichiroMatsubara/HayateProjects"
  },
