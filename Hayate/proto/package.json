  "exports": {
    "./manifest": "./spec/manifest.json",
    "./types": "./spec/types.json",
    "./enums": "./spec/enums.json",
    "./opcodes": "./spec/opcodes.json",
    "./style_tags": "./spec/style_tags.json",
    "./event_kinds": "./spec/event_kinds.json",
    "./edit_intents": "./spec/edit_intents.json",
    "./element_kinds": "./spec/element_kinds.json",
    "./unset_kinds": "./spec/unset_kinds.json",
    "./modifier_keys": "./spec/modifier_keys.json",
    "./pseudo_states": "./spec/pseudo_states.json",
    "./load": "./scripts/load-spec.mjs"
  },
  "scripts": {
    "prepublishOnly": "node -e \"process.env.GITHUB_ACTIONS||(console.error('publish only via the release workflow (ADR-0007 §4)'),process.exit(1))\"",
    "validate": "node scripts/validate-spec.mjs"
  },
  "devDependencies": {
    "ajv": "^8.17.1"
  }
