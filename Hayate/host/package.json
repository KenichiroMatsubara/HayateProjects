{
  "name": "@torimi/hayate-host",
  "version": "0.1.0",
  "description": "Hayate JS host glue — web bootstrap (WebGPU probe / backend 選択 / WASM ロード / surface 取得) と native pump。RawHayate を返し、Tsubame の host-blind HayateRenderer を駆動する合成ルートへ渡す（CONTEXT-MAP / ADR-0117）。",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/KenichiroMatsubara/HayateProjects"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./native": {
      "types": "./dist/native.d.ts",
      "import": "./dist/native.js"
    },
    "./renderer-policy": {
      "types": "./dist/renderer-policy.d.ts",
      "import": "./dist/renderer-policy.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prepublishOnly": "node -e \"process.env.GITHUB_ACTIONS||(console.error('publish only via the release workflow (ADR-0007 §4)'),process.exit(1))\"",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@torimi/hayate-protocol-spec": "workspace:*",
    "@torimi/hayate-adapter-web": "workspace:*",
    "@torimi/hayate-adapter-web-cpu": "workspace:*"
  },
  "devDependencies": {
    "happy-dom": "^17.4.4",
    "rimraf": "^6.1.3",
    "vitest": "^3.2.0"
  }
}
