{
  "crateDir": "crates/platform/web",
  "npmPackageName": "hayate-adapter-web",
  "targets": [
    {
      "name": "pkg",
      "outDir": "wasm-pkgs/pkg",
      "targetDir": "target/wasm",
      "cargoFeatures": { "mode": "inherit", "names": [] },
      "description": "Hayate — GPU-native UI substrate",
      "includeInDefaultBuild": true
    },
    {
      "name": "pkg-tiny-skia",
      "outDir": "wasm-pkgs/pkg-tiny-skia",
      "targetDir": "target/wasm-tiny-skia",
      "cargoFeatures": { "mode": "exclusive", "names": ["backend-tiny-skia"] },
      "description": "Hayate — GPU-native UI substrate",
      "includeInDefaultBuild": true
    },
    {
      "name": "pkg-vello-cpu",
      "outDir": "wasm-pkgs/pkg-vello-cpu",
      "targetDir": "target/wasm-vello-cpu",
      "cargoFeatures": { "mode": "exclusive", "names": ["backend-vello-cpu"] },
      "description": "Hayate — GPU-native UI substrate",
      "includeInDefaultBuild": true
    },
    {
      "name": "pkg-null",
      "outDir": "wasm-pkgs/pkg-null",
      "targetDir": "target/wasm-null",
      "cargoFeatures": { "mode": "exclusive", "names": ["backend-null"] },
      "description": "Hayate — GPU-native UI substrate",
      "includeInDefaultBuild": true
    },
    {
      "name": "pkg-layer-present",
      "outDir": "wasm-pkgs/pkg-layer-present",
      "targetDir": "target/wasm-layer-present",
      "cargoFeatures": { "mode": "additive", "names": ["layer-present"] },
      "description": "Hayate — GPU-native UI substrate (layer-present feature, #697 E2E harness only)",
      "includeInDefaultBuild": false
    }
  ]
}
