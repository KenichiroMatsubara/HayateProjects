{
  "crateDir": "crates/platform/web",
  "npmPackageName": "@torimi/hayate-adapter-web",
  "targets": [
    {
      "name": "pkg",
      "outDir": "wasm-pkgs/pkg",
      "targetDir": "target/wasm",
      "cargoFeatures": { "mode": "inherit", "names": [] },
      "description": "Hayate — GPU-native UI substrate",
      "includeInDefaultBuild": true,
      "npmName": "@torimi/hayate-adapter-web",
      "host": { "backend": "vello", "runtimeLayerPresentArg": "layerPresent" }
    },
    {
      "name": "pkg-tiny-skia",
      "outDir": "wasm-pkgs/pkg-tiny-skia",
      "targetDir": "target/wasm-tiny-skia",
      "cargoFeatures": { "mode": "exclusive", "names": ["backend-tiny-skia"] },
      "description": "Hayate — GPU-native UI substrate",
      "includeInDefaultBuild": true,
      "npmName": "@torimi/hayate-adapter-web-cpu",
      "host": { "backend": "tiny-skia", "runtimeLayerPresentArg": "cpuLayerPresent" }
    },
    {
      "name": "pkg-vello-cpu",
      "outDir": "wasm-pkgs/pkg-vello-cpu",
      "targetDir": "target/wasm-vello-cpu",
      "cargoFeatures": { "mode": "exclusive", "names": ["backend-vello-cpu"] },
      "description": "Hayate — GPU-native UI substrate",
      "includeInDefaultBuild": true,
      "npmName": "@torimi/hayate-adapter-web-vello-cpu",
      "host": { "backend": "vello-cpu", "runtimeLayerPresentArg": "cpuLayerPresent" }
    },
    {
      "name": "pkg-canvaskit",
      "outDir": "wasm-pkgs/pkg-canvaskit",
      "targetDir": "target/wasm-canvaskit",
      "cargoFeatures": { "mode": "exclusive", "names": ["backend-canvaskit"] },
      "description": "Hayate — GPU-native UI substrate",
      "includeInDefaultBuild": false,
      "npmName": "@torimi/hayate-adapter-web-skia",
      "comment": "ADR-0148 DRAFT / Phase 2: Skia CanvasKit backend. host は null のまま — 実 npm パッケージがビルドできてから host:{backend:'canvaskit',runtimeLayerPresentArg:'cpuLayerPresent'} に切替え、generate:canvas-backend でローダを再生成する。CanvasKit(canvaskit-wasm)の asset 配信も要結線。既定ビルド対象外。",
      "host": null
    },
    {
      "name": "pkg-null",
      "outDir": "wasm-pkgs/pkg-null",
      "targetDir": "target/wasm-null",
      "cargoFeatures": { "mode": "exclusive", "names": ["backend-null"] },
      "description": "Hayate — GPU-native UI substrate",
      "includeInDefaultBuild": true,
      "npmName": "hayate-adapter-web-null",
      "private": true,
      "host": null
    }
  ]
}
