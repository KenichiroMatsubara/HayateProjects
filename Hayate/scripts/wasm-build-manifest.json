{
  "crateDir": "crates/platform/web",
  "npmPackageName": "@torimi/hayate-adapter-web",
  "targets": [
    {
      "name": "pkg",
      "outDir": "wasm-pkgs/pkg",
      "targetDir": "target/wasm",
      "cargoFeatures": { "mode": "inherit", "names": [] },
      "description": "Hayate — GPU-native UI substrate",
      "includeInDefaultBuild": true,
      "npmName": "@torimi/hayate-adapter-web",
      "host": { "backend": "vello" }
    },
    {
      "name": "pkg-tiny-skia",
      "outDir": "wasm-pkgs/pkg-tiny-skia",
      "targetDir": "target/wasm-tiny-skia",
      "cargoFeatures": { "mode": "exclusive", "names": ["backend-tiny-skia"] },
      "description": "Hayate — GPU-native UI substrate",
      "includeInDefaultBuild": true,
      "npmName": "@torimi/hayate-adapter-web-cpu",
      "host": { "backend": "tiny-skia" }
    },
    {
      "name": "pkg-null",
      "outDir": "wasm-pkgs/pkg-null",
      "targetDir": "target/wasm-null",
      "cargoFeatures": { "mode": "exclusive", "names": ["backend-null"] },
      "description": "Hayate — GPU-native UI substrate",
      "includeInDefaultBuild": true,
      "npmName": "hayate-adapter-web-null",
      "private": true,
      "host": null
    }
  ]
}
