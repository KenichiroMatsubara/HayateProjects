package hayate:core@0.1.0;

// ─── Types ───────────────────────────────────────────────────────────────────

interface types {
  type element-id = u64;

  enum element-kind {
    view,
    text,
    image,
    button,
    text-input,
    scroll-view,
  }

  // Dimension
  enum dimension-unit { px, percent, auto, fr }
  record dimension {
    value: f32,
    unit: dimension-unit,
  }

  // Color (linear RGBA)
  record color {
    r: f32,
    g: f32,
    b: f32,
    a: f32,
  }

  // 2D affine transform matrix (column-major, matches Vello Affine)
  // [ xx  xy  dx ]
  // [ yx  yy  dy ]
  record affine {
    xx: f64,
    yx: f64,
    xy: f64,
    yy: f64,
    dx: f64,
    dy: f64,
  }

  // Bounding box in canvas coordinates (after layout)
  record bounds {
    x: f32,
    y: f32,
    width: f32,
    height: f32,
  }

  // Layout
  enum display-value { flex, grid, block, none }
  enum align-value { flex-start, flex-end, center, stretch, baseline }
  enum justify-value { flex-start, flex-end, center, space-between, space-around, space-evenly }
  enum flex-direction-value { row, column, row-reverse, column-reverse }

  // Hayate CSS — style properties as variant list
  variant style-prop {
    // visual
    background-color(color),
    opacity(f32),
    border-radius(f32),
    border-width(f32),
    border-color(color),
    // sizing
    width(dimension),
    height(dimension),
    min-width(dimension),
    min-height(dimension),
    max-width(dimension),
    max-height(dimension),
    // layout
    display(display-value),
    flex-direction(flex-direction-value),
    align-items(align-value),
    justify-content(justify-value),
    gap(dimension),
    padding(dimension),
    padding-top(dimension),
    padding-right(dimension),
    padding-bottom(dimension),
    padding-left(dimension),
    margin(dimension),
    margin-top(dimension),
    margin-right(dimension),
    margin-bottom(dimension),
    margin-left(dimension),
    // text
    font-size(f32),
    font-family(string),
    color(color),
    // stacking
    z-index(s32),
  }

  // ── Event types ──────────────────────────────────────────────────────────

  record click-event {
    target: element-id,
    x: f32,
    y: f32,
  }
  record text-input-event {
    target: element-id,
    text: string,
  }
  record composition-event {
    target: element-id,
    text: string,
  }
  record scroll-event {
    target: element-id,
    delta-x: f32,
    delta-y: f32,
  }
  record resize-event {
    width: f32,
    height: f32,
  }

  // Keyboard modifier keys bitmask (ADR-0031)
  flags modifier-keys {
    shift,
    ctrl,
    alt,
    meta,
  }
  record key-down-event {
    target: element-id,
    // Key identifier following Web KeyboardEvent.key convention
    // (e.g. "a", "A", "Enter", "Backspace", "ArrowUp")
    key: string,
    modifiers: modifier-keys,
  }

  // Raw pointer position in canvas coordinates; no target (ADR-0031)
  record pointer-move-event {
    x: f32,
    y: f32,
  }

  // All events emitted by Hayate and polled by the upper layer (ADR-0018, ADR-0031)
  variant event {
    // pointer / interaction
    click(click-event),
    hover-enter(element-id),
    hover-leave(element-id),
    active-start(element-id),
    active-end(element-id),
    pointer-move(pointer-move-event),
    // keyboard
    key-down(key-down-event),
    // focus
    focus(element-id),
    blur(element-id),
    // text / IME
    text-input(text-input-event),
    composition-start(composition-event),
    composition-update(composition-event),
    composition-end(composition-event),
    // viewport
    scroll(scroll-event),
    resize(resize-event),
  }
}

// ─── Element Layer ────────────────────────────────────────────────────────────

interface element-layer {
  use types.{
    element-id, element-kind,
    style-prop, event,
    affine, bounds,
  };

  // ── Element tree management ──────────────────────────────────────────────
  // id is caller-assigned (monotonic counter on the upper layer side).
  element-create: func(id: element-id, kind: element-kind);
  element-set-text: func(id: element-id, text: string) -> ();
  element-set-src: func(id: element-id, url: string) -> ();
  element-set-transform: func(id: element-id, matrix: affine) -> ();
  element-set-scroll-offset: func(id: element-id, x: f32, y: f32) -> ();
  element-set-style: func(id: element-id, props: list<style-prop>) -> ();
  element-append-child: func(parent: element-id, child: element-id) -> ();
  element-insert-before: func(parent: element-id, child: element-id, before: element-id) -> ();
  element-remove: func(id: element-id) -> ();

  // ── Getters ──────────────────────────────────────────────────────────────
  element-get-text: func(id: element-id) -> string;
  element-get-bounds: func(id: element-id) -> bounds;

  // ── Input ────────────────────────────────────────────────────────────────
  // Deliver pasted text to a text-input element (ADR-0031)
  element-paste: func(id: element-id, text: string) -> ();
  // Load a custom font from raw bytes into the font registry (ADR-0028)
  element-load-font: func(data: list<u8>) -> ();

  // ── Batch mutations (ADR-0039) ───────────────────────────────────────────
  // Hot path called once per frame by Canvas Renderer.
  // ops:    fixed-length f64 records (op_kind + operands per ADR-0039 table).
  // styles: flat f32 style-packet buffer referenced by OP_SET_STYLE offsets.
  apply-mutations: func(ops: list<f64>, styles: list<f32>);

  // ── Frame lifecycle ──────────────────────────────────────────────────────
  // timestamp-ms: monotonic milliseconds from the host (e.g. performance.now()).
  // Used internally for cursor blink timing (ADR-0032).
  render: func(timestamp-ms: f64) -> ();
  poll-events: func() -> list<event>;
}

// ─── Raw Layer ────────────────────────────────────────────────────────────────
//
// Raw Layer is defined but NOT exported from the world until the full set of
// node operations is implemented and a concrete use case (game HUD, Infinite
// Canvas) exists. See ADR-0033.

interface raw-layer {
  use types.{color};

  type node-id = u64;

  record rect-desc {
    x: f32,
    y: f32,
    width: f32,
    height: f32,
    color: color,
    corner-radius: f32,
  }

  create-rect: func(desc: rect-desc) -> node-id;
  node-remove: func(id: node-id) -> ();
  render: func(background: color) -> ();
}

// ─── World ────────────────────────────────────────────────────────────────────

world hayate {
  export element-layer;
  // raw-layer is intentionally omitted until ADR-0033 is resolved.
}
